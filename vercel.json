{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": true,
  "functions": {
    "api/telegram.js": {
      "runtime": "nodejs22.x"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
